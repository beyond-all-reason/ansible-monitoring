[Unit]
Description=SmokePing Prober
After=network.target

[Service]
ExecStart={{ smokeping_prober_bin_path }} --web.listen-address=127.0.0.1:9374 --buckets="0.001,0.002,0.003,0.004,0.007,0.01,0.017,0.027,0.043,0.069,0.11,0.176,0.281,0.45,0.721,1.15,1.84,2.95,4.72,7.55,12.0,19.0,30.0" --ping.interval=0.5s --privileged {{ smokeping_prober_targets }}
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
