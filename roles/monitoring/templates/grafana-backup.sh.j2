#!/bin/bash

set -e -u -o pipefail

# Grafana database backup script
# Backs up the Grafana SQLite database to configured cloud storage

if [[ $(id -u) != 0 ]]; then
    echo "This script must be run as root" >&2
    exit 1
fi

# Create backup directory
mkdir -p /var/tmp/backup
chmod 700 /var/tmp/backup

# Generate backup filename with timestamp
BACKUP_FILE="grafana-$(date +%Y%m%d%H%M%S).db.zst"
GRAFANA_DB="/var/lib/containers/storage/volumes/grafana_data/_data/grafana.db"

# Check if Grafana database exists
if [[ ! -f "$GRAFANA_DB" ]]; then
    echo "Grafana database not found at $GRAFANA_DB" >&2
    exit 1
fi

echo "Starting Grafana database backup..."

# Create compressed backup
# We use cp to copy the database file, then compress it
# SQLite database can be copied safely while running
cp "$GRAFANA_DB" "/var/tmp/backup/grafana.db"
zstd --long -9 --stdout "/var/tmp/backup/grafana.db" > "/var/tmp/backup/$BACKUP_FILE"

# Remove uncompressed copy
rm -f "/var/tmp/backup/grafana.db"

echo "Backup created: $BACKUP_FILE"

# Upload to cloud storage using rclone
echo "Uploading backup to cloud storage..."
rclone --config /usr/local/etc/backup/rclone.conf copyto "/var/tmp/backup/$BACKUP_FILE" "backup:{{ backup_path }}/$BACKUP_FILE"

echo "Backup uploaded successfully"

# Clean up local backup files (keep only current one)
find /var/tmp/backup -name "grafana-*.db.zst" -type f ! -name "$BACKUP_FILE" -delete

echo "Grafana database backup completed: $BACKUP_FILE"
